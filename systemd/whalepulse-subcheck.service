[Unit]
Description=WhalePulse Subscription Checker
After=network.target

[Service]
Type=simple
User=botrunner
WorkingDirectory=/home/botrunner/whalepulse
Environment=PYTHONPATH=/home/botrunner/whalepulse
ExecStart=/home/botrunner/whalepulse/venv/bin/python bots/payments/subscription_checker.py
Restart=always
RestartSec=30
StandardOutput=append:/home/botrunner/whalepulse/logs/subcheck-stdout.log
StandardError=append:/home/botrunner/whalepulse/logs/subcheck-stderr.log

[Install]
WantedBy=multi-user.target
